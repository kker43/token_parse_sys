[Unit]
Description=token_parse_sys daily fact production wrapper
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/ubuntu/token_parse_sys
ExecStart=/usr/bin/python3 /home/ubuntu/token_parse_sys/workflows/jobs/daily_fact_data_production.py --schedule-config-path /home/ubuntu/token_parse_sys/configs/schedules/daily_fact_data_production.json
User=ubuntu
Group=ubuntu

