{
  "strategy_id": "strategy.steady_uptrend_pre_breakout_watch",
  "version": "candidate_v1",
  "status": "draft",
  "name": "稳健上升趋势突破前准备态关注策略",
  "description": "在周级别上升趋势背景和日线稳健趋势成立的前提下，寻找接近 60 日高点但尚未确认突破、量能不弱、MA20 乖离不过度的预突破候选；当前不按技术评分截断 Top N。",
  "parent_strategy_id": "strategy.steady_uptrend_breakout_watch",
  "candidate_pool": {
    "policy_id": "strategy.steady_uptrend_pre_breakout_watch.pool",
    "version": "candidate_v1",
    "source_type": "l3_label_recall",
    "parameters": {
      "labels": [
        "technical_pattern.steady_uptrend_pre_breakout_watch"
      ],
      "market": "CN_A"
    }
  },
  "pipeline": [
    {
      "stage_id": "quality_gate",
      "stage_type": "filter",
      "pass_conditions": [
        "quality_gate.snapshot_consumable == true"
      ]
    },
    {
      "stage_id": "hard_exclusion_filter",
      "stage_type": "filter",
      "pass_conditions": [
        "asset_state.normal_listing == true",
        "liquidity.total_mv_ge_100e == true",
        "liquidity.avg_amount_20d_ge_2e == true",
        "risk.turnover_rate_20d_controlled == true"
      ],
      "notes": "先剔除 ST/非正常上市、总市值小于 100 亿、近 20 日平均成交额小于 2 亿、近 20 日存在换手率超过 20% 的股票。"
    },
    {
      "stage_id": "weekly_context_filter",
      "stage_type": "filter",
      "pass_conditions": [
        "technical_context.weekly_uptrend_context == true"
      ]
    },
    {
      "stage_id": "industry_concept_context_filter",
      "stage_type": "filter",
      "pass_conditions": [
        "context.strong_industry_or_concept == true"
      ],
      "logic": "strong_industry_hit OR strong_concept_hit",
      "notes": "强行业/强概念任一命中即可通过；强行业/强概念由趋势强 OR 热度强合并得到。"
    },
    {
      "stage_id": "daily_steady_trend_filter",
      "stage_type": "filter",
      "pass_conditions": [
        "technical_pattern.steady_uptrend_stock == true",
        "moving_average.ma30_hold_ratio_90d_sustained == true",
        "risk.ma30_deviation_not_extreme == true"
      ]
    },
    {
      "stage_id": "pre_breakout_recall",
      "stage_type": "recall",
      "pass_conditions": [
        "technical_pattern.steady_uptrend_pre_breakout_watch == true"
      ]
    },
    {
      "stage_id": "ranking_diagnostic",
      "stage_type": "observe",
      "status": "disabled_for_decision",
      "score_fields": [
        "setup_score",
        "red_k_ratio_score",
        "drawdown_control_score",
        "shadow_noise_score",
        "near_high_score"
      ],
      "missing_context_dimensions": [
        "context_industry.industry_relative_strength",
        "context_theme.hot_theme_active",
        "fundamental_quality.profitability_stable",
        "fundamental_growth.growth_acceleration",
        "context_market.market_regime"
      ],
      "decision_policy": {
        "use_for_top_n": false,
        "reason": "当前 setup_score 只覆盖技术形态，不包含行业、题材、基本面和市场环境，不能作为少量个股截断依据。"
      }
    }
  ],
  "candidate_scan_policy": {
    "candidate_mode": "pre_breakout",
    "top_n_per_date": null,
    "min_close_to_high_60d_pct": -0.08,
    "max_close_to_high_60d_pct": -0.002,
    "min_volume_ratio_5d_20d": 1.2,
    "max_ma20_deviation_pct": 0.35,
    "max_ma30_deviation_pct": 0.35,
    "preferred_ma30_deviation_pct": 0.25,
    "min_sustained_ma30_hold_ratio_90d": 0.75,
    "quality_ma30_hold_ratio_90d": 0.8,
    "require_pre_breakout_sustained_ma30": true,
    "require_weekly_uptrend": true,
    "require_normal_listing": true,
    "min_total_mv": 1000000,
    "min_avg_amount_20d": 200000,
    "min_avg_amount_20d_note": "输入单位为千元人民币；200,000 千元对应 2 亿元。",
    "max_turnover_rate_20d": 20,
    "require_context_strength": true,
    "context_strength_definition": {
      "pass_logic": "strong_industry_hit OR strong_concept_hit",
      "trend_strong": [
        "index_20d_return_rank_pct <= 30%",
        "index_close > index_ma20",
        "index_close > index_ma60"
      ],
      "heat_strong": [
        "past_20_trade_days_top200_gainers_member_distribution_daily_top5_hit_count >= 3",
        "recent_5_trade_days_top5_hit_count >= 1"
      ]
    }
  },
  "notes": "第二版增加硬过滤、MA30 稳健性和强行业/强概念上下文过滤。setup_score 仍仅作为诊断字段；在补齐基本面和市场环境后，再建设多维评分与少量 Top N 观察池。"
}
