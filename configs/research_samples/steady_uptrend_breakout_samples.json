  "core_hypothesis": {
    "summary": "个股已经处于周线或日线级别上升趋势，日线在整理、蓄势、接近前高或平台上沿后向上突破；强势股应具备均线多头、价格大多位于中短期均线上方、回撤受控、红 K 占比较高、量能或动量确认等特征。",
    "positive_signal": [
      "weekly_uptrend_context",
      "daily_ma_bullish_or_diverging",
      "price_above_key_moving_averages",
      "near_recent_high_or_base_upper_range",
      "breakout_with_momentum_or_volume",
      "trend_quality_stable"
    ],
    "negative_or_risk_signal": [
      "overextended_from_ma30_or_ma60",
      "frequent_break_ma30",
      "green_k_ratio_high",
      "post_breakout_drawdown_large",
      "late_stage_high_level_extension"
    ]
  },
